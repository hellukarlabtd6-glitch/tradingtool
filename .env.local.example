# ---- Required ----

# Your Stripe SECRET key. Test mode starts with sk_test_, live mode with sk_live_
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxx

# The recurring Price ID for your subscription product (looks like price_xxx)
STRIPE_PRICE_ID=price_xxxxxxxxxxxxxxxxxxxxxxxx

# A long random string used to sign access cookies.
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=replace_me_with_a_long_random_string

# ---- Optional ----

# Only needed for local dev or a custom domain. On Vercel this is auto-detected.
# NEXT_PUBLIC_BASE_URL=http://localhost:3000
